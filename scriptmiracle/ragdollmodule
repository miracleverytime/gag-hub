local function ToggleMotor6D(p1, p2) --[[ ToggleMotor6D | Line: 26 ]]
	for k, v in pairs(p1.Torso:GetDescendants()) do
		if v:IsA("Motor6D") then
			v.Enabled = p2
		end
	end
end

local function ToggleCollisionParts(p1, p2) --[[ ToggleCollisionParts | Line: 34 ]]
	if p2 then
		for k, v in pairs(p1:GetChildren()) do
			if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
				local Collider = v:Clone()

				Collider.Size = v.Size * 0.75
				Collider.CanCollide = true
				Collider.Massless = true
				Collider.Name = "Collider"
				Collider.Transparency = 1
				Collider.Parent = p1

				local Weld = Instance.new("Weld")

				Weld.Part0 = v
				Weld.Part1 = Collider
				Weld.Parent = Collider
			end
		end
	else
		for k, v in pairs(p1:GetChildren()) do
			if v.Name == "Collider" then
				v:Destroy()
			end
		end
	end
end

local function BuildConstraints(p1, p2) --[[ BuildConstraints | Line: 61 | Upvalues: t2 (copy) ]]
	local Torso = p1:FindFirstChild("Torso")

	if p2 then
		for k, v in pairs(p1.Torso:GetChildren()) do
			if v:IsA("Motor6D") then
				local RagdollAttachment = Instance.new("Attachment")
				local RagdollAttachment2 = Instance.new("Attachment")
				local RagdollConstraint = Instance.new("BallSocketConstraint")

				RagdollAttachment.Name = "RagdollAttachment"
				RagdollAttachment.CFrame = t2[v.Name].CF[2]
				RagdollAttachment.Parent = v.Part1
				RagdollAttachment2.Name = "RagdollAttachment"
				RagdollAttachment2.CFrame = t2[v.Name].CF[1]
				RagdollAttachment2.Parent = Torso
				RagdollConstraint.Name = "RagdollConstraint"
				RagdollConstraint.Attachment0 = RagdollAttachment
				RagdollConstraint.Attachment1 = RagdollAttachment2
				RagdollConstraint.LimitsEnabled = true
				RagdollConstraint.UpperAngle = 180
				RagdollConstraint.TwistLimitsEnabled = true
				RagdollConstraint.TwistLowerAngle = -90
				RagdollConstraint.TwistUpperAngle = 90
				RagdollConstraint.Parent = Torso
				v.Part1.CollisionGroup = "Ragdoll"
			end
		end
	else
		for k, v in pairs(Torso:GetChildren()) do
			if v.Name == "RagdollConstraint" then
				v.Attachment0:Destroy()
				v.Attachment1:Destroy()
				v:Destroy()

				continue
			end

			if v:IsA("Motor6D") then
				v.Part1.CollisionGroup = "Default"
			end
		end
	end
end

function t.Unragdoll(p1, p2) --[[ Unragdoll | Line: 107 | Upvalues: Players (copy), ToggleMotor6D (copy), BuildConstraints (copy) ]]
	local v1 = p2:FindFirstChildWhichIsA("Humanoid")

	Players:GetPlayerFromCharacter(p2)

	if v1:GetState() == Enum.HumanoidStateType.Dead then
		return
	end

	if not v1.RootPart then
		return
	end

	p2:SetAttribute("Ragdolled", nil)
	ToggleMotor6D(p2, true)

	for k, v in pairs(p2:GetChildren()) do
		if v.Name == "Collider" then
			v:Destroy()
		end
	end

	BuildConstraints(p2, false)
	v1.AutoRotate = true
	v1.PlatformStand = false
	v1:ChangeState(Enum.HumanoidStateType.GettingUp)
end
